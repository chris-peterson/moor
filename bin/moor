#!/bin/bash
# moor — production launcher
# Usage:
#   moor dir1 dir2                          # compare directories
#   moor file1 file2                         # compare files
#   moor --context <path> dir1 dir2          # capture review output via MOOR_CONTEXT contract

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMPL_DIR="$SCRIPT_DIR/.."

# Build if dist doesn't exist
if [ ! -d "$IMPL_DIR/dist" ]; then
    echo "Building moor..." >&2
    (cd "$IMPL_DIR" && ./node_modules/.bin/vite build --quiet) || exit 1
fi

# Electron-based editors (VS Code, Cursor) set ELECTRON_RUN_AS_NODE=1
# in their integrated terminal so child processes don't accidentally
# spin up Electron windows. But we *want* Electron here — unset it.
unset ELECTRON_RUN_AS_NODE

exec "$IMPL_DIR/node_modules/.bin/electron" "$IMPL_DIR" "$@"
