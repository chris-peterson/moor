spec := "0.2"
impl := "1-react"

impl_dir := "implementations" / spec / impl
sample_dir := justfile_directory() / "sample_data"

install:
    cd {{impl_dir}} && npm install

build:
    cd {{impl_dir}} && ./node_modules/.bin/vite build

test:
    cd {{impl_dir}} && npm test

sample-data:
    bash scripts/create-sample-data.sh

diff *flags: sample-data build (_diff flags)

_diff flags:
    #!/usr/bin/env bash
    ./bin/kdiff4 {{sample_dir}}/left/src/utils.js {{sample_dir}}/right/src/utils.js &
    if echo "{{flags}}" | grep -q -- "--legacy"; then
        kdiff3 {{sample_dir}}/left/src/utils.js {{sample_dir}}/right/src/utils.js &
    fi
    wait

gitconfig_repo := home_directory() / "src/getty/cpeterson/gitconfig"

git-install: build
    git config --global diff.tool kdiff4
    git config --global difftool.kdiff4.cmd '{{justfile_directory()}}/bin/kdiff4 "$LOCAL" "$REMOTE"'
    git config --global merge.tool vscode
    git config --global mergetool.vscode.cmd 'code --wait $MERGED'
    @echo "Installed: diff.tool=kdiff4, merge.tool=vscode"

git-uninstall:
    git config --global --remove-section difftool.kdiff4 2>/dev/null || true
    cd {{gitconfig_repo}} && bash update.sh
    @echo "Restored git config from {{gitconfig_repo}}"
