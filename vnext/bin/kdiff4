#!/bin/bash
# kdiff4 — production launcher
# Usage:
#   kdiff4 dir1 dir2                          # compare directories
#   kdiff4 file1 file2                         # compare files
#   kdiff4 -m base left right -o output        # 3-way merge

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMPL_DIR="$SCRIPT_DIR/../implementations/0.2/1-react"

# Build if dist doesn't exist
if [ ! -d "$IMPL_DIR/dist" ]; then
    echo "Building kdiff4..." >&2
    (cd "$IMPL_DIR" && ./node_modules/.bin/vite build --quiet) || exit 1
fi

exec "$IMPL_DIR/node_modules/.bin/electron" "$IMPL_DIR" "$@"
